-- Inicializa Rayfield (uma única vez)
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()  

-- Cria a janela principal
local Window = Rayfield:CreateWindow({
    Name = "Cardox Hub - v3",
    LoadingTitle = "Carregando...",
    LoadingSubtitle = "Por Trae AI x Cardox x GPT",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "CardoxHubV3", 
        FileName = "Config"
    },
    Discord = {
        Enabled = false,
    },
    KeySystem = false
})

-- Cria abas (tabs)
local PlayerTab = Window:CreateTab("Player", 4483362458)
local VisualsTab = Window:CreateTab("Visuals", 4483362458)
local TrollTab = Window:CreateTab("Troll", 4483362458)
local AnimTab = Window:CreateTab("Animações", 4483362458)

-- Carrega os módulos (pastas/arquivos)
-- Nota: Em executores Roblox, o acesso a pastas pode variar. 
-- Usamos script.Parent se href v3 estiver na mesma pasta que as outras.
local MainFolder = script.Parent

local Anim = require(MainFolder:WaitForChild("Anim"):WaitForChild("anim.lua"))
local Player = require(MainFolder:WaitForChild("Player"):WaitForChild("player.lua"))
local Troll = require(MainFolder:WaitForChild("Troll"):WaitForChild("troll.lua"))
local Visuals = require(MainFolder:WaitForChild("Visuals"):WaitForChild("visual.lua"))

-- Inicializa cada aba com suas funções
if Player.Init then Player.Init(PlayerTab) end
if Visuals.Init then Visuals.Init(VisualsTab, Rayfield) end
if Troll.Init then Troll.Init(TrollTab) end
if Anim.Init then Anim.Init(AnimTab) end

-- Notificação de sucesso
Rayfield:Notify({
    Title = "Hub Carregado!",
    Content = "Cardox Hub v3 inicializado com sucesso.",
    Duration = 5,
    Image = 4483362458,
})
